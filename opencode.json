{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.4",
  "mcp": {
    "better-auth": {
      "type": "remote",
      "url": "https://mcp.better-auth.com/mcp",
      "enabled": true
    },
    "exa": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp",
      "enabled": true
    },
    "gmail": {
      "type": "local",
      "command": ["npx", "-y", "@google/gmail-mcp-server"],
      "enabled": true
    },
    "google-calendar": {
      "type": "local",
      "command": ["npx", "-y", "@google/calendar-mcp-server"],
      "enabled": true
    },
    "google-drive": {
      "type": "local",
      "command": ["npx", "-y", "@google/drive-mcp-server"],
      "enabled": true
    },
    "github": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-github"],
      "enabled": false,
      "environment": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "{env:TINKER_GITHUB_TOKEN}"
      }
    },
    "linear": {
      "type": "local",
      "command": ["npx", "-y", "@tacticlaunch/mcp-linear"],
      "enabled": false,
      "environment": {
        "LINEAR_API_KEY": "{env:LINEAR_API_KEY}"
      }
    },
    "qmd": {
      "type": "local",
      "command": ["npx", "-y", "@tobilu/qmd", "mcp"],
      "enabled": true
    },
    "smart-connections": {
      "type": "local",
      "command": ["npx", "-y", "github:msdanyg/smart-connections-mcp"],
      "enabled": true,
      "environment": {
        "SMART_VAULT_PATH": "{env:SMART_VAULT_PATH}"
      }
    }
  }
}

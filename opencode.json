{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.4",
  "mcp": {
    "exa": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp",
      "enabled": true
    },
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "enabled": true,
      "oauth": false,
      "headers": {
        "Authorization": "{env:TINKER_GITHUB_AUTHORIZATION}"
      }
    },
    "linear": {
      "type": "remote",
      "url": "https://mcp.linear.app/mcp",
      "enabled": true,
      "headers": {
        "Authorization": "{env:TINKER_LINEAR_AUTHORIZATION}"
      }
    },
    "qmd": {
      "type": "local",
      "command": ["npx", "-y", "@tobilu/qmd", "mcp"],
      "enabled": true
    },
    "smart-connections": {
      "type": "local",
      "command": ["npx", "-y", "github:msdanyg/smart-connections-mcp"],
      "enabled": true
    }
  }
}

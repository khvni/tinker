{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.4",
  "mcp": {
    "exa": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp",
      "enabled": true
    },
    "qmd": {
      "type": "local",
      "command": ["npx", "-y", "@tobilu/qmd", "mcp"],
      "enabled": true
    },
    "smart-connections": {
      "type": "local",
      "command": ["npx", "-y", "github:msdanyg/smart-connections-mcp"],
      "enabled": true
    }
  }
}

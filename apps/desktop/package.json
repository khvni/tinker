{
  "name": "@tinker/desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist-electron/main.mjs",
  "scripts": {
    "dev": "node scripts/dev-electron.mjs",
    "dev:web": "vite",
    "dev:design": "vite --open /?route=design-system",
    "build": "tsc -p tsconfig.json --noEmit && node scripts/build-electron.mjs",
    "build:electron": "node scripts/build-electron.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "typecheck:electron": "tsc -p tsconfig.electron.json --noEmit",
    "lint": "eslint src",
    "test": "vitest run --passWithNoTests",
    "test:visual": "playwright test --config=playwright.visual.config.ts",
    "test:visual:update": "UPDATE_BASELINES=1 playwright test --config=playwright.visual.config.ts",
    "package": "electron-builder --config electron-builder.yml",
    "package:mac": "electron-builder --mac --config electron-builder.yml",
    "package:win": "electron-builder --win --config electron-builder.yml"
  },
  "dependencies": {
    "@fontsource-variable/host-grotesk": "^5.0.0",
    "@opencode-ai/sdk": "^1.4.3",
    "@tinker/attention": "workspace:*",
    "@tinker/bridge": "workspace:*",
    "@tinker/design": "workspace:*",
    "@tinker/host-client": "workspace:*",
    "@tinker/memory": "workspace:*",
    "@tinker/scheduler": "workspace:*",
    "@tinker/shared-types": "workspace:*",
    "dompurify": "^3.4.0",
    "exceljs": "^4.4.0",
    "flexlayout-react": "^0.9.0",
    "highlight.js": "^11.11.1",
    "mammoth": "^1.12.0",
    "marked": "^18.0.0",
    "papaparse": "^5.5.3",
    "pdfjs-dist": "4.7.76",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^9.0.1",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/papaparse": "^5.5.2",
    "@types/pngjs": "^6.0.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.3",
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0",
    "esbuild": "^0.25.0",
    "pixelmatch": "^6.0.0",
    "pngjs": "^7.0.0",
    "typescript": "^5.6.3",
    "vite": "^6.0.1",
    "vitest": "^2.1.0"
  }
}

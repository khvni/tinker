{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability set for the main Tinker window.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "shell:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "git",
          "cmd": "git",
          "args": true,
          "sidecar": false
        }
      ]
    },
    "sql:default",
    "sql:allow-execute",
    "keyring:default",
    "notification:default",
    "allow-folder-picker",
    "allow-get-opencode-connection",
    "allow-oauth-flow",
    "allow-restart-opencode",
    "fs:default",
    "fs:allow-home-read-recursive",
    "fs:allow-home-write-recursive"
  ]
}

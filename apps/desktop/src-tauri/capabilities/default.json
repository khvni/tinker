{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability set for the main Tinker window.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "shell:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "git",
          "cmd": "git",
          "args": true,
          "sidecar": false
        }
      ]
    },
    "sql:default",
    "sql:allow-execute",
    "keyring:default",
    "notification:default",
    "allow-folder-picker",
    "allow-oauth-flow",
    "allow-refresh-token-keychain",
    "allow-mcp-secret-keychain",
    "allow-start-opencode",
    "allow-stop-opencode",
    "allow-memory-review",
    "fs:default",
    "fs:allow-home-read-recursive",
    "fs:allow-home-write-recursive",
    "fs:allow-home-meta-recursive",
    "fs:allow-localdata-read-recursive",
    "fs:allow-localdata-write-recursive",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$HOME/**" },
        { "path": "$HOME/**/.*" },
        { "path": "$HOME/**/.*/**" },
        { "path": "$APPDATA/**" },
        { "path": "$APPDATA/**/.*" },
        { "path": "$APPDATA/**/.*/**" },
        { "path": "$APPLOCALDATA/**" },
        { "path": "$APPLOCALDATA/**/.*" },
        { "path": "$APPLOCALDATA/**/.*/**" },
        { "path": "$LOCALDATA/**" },
        { "path": "$LOCALDATA/**/.*" },
        { "path": "$LOCALDATA/**/.*/**" }
      ]
    },
    {
      "identifier": "fs:allow-exists",
      "allow": [
        { "path": "$HOME/**" },
        { "path": "$HOME/**/.*" },
        { "path": "$HOME/**/.*/**" }
      ]
    }
  ]
}

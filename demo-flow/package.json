{
  "name": "tinker-demo-flow",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --host",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host",
    "shell": "concurrently -k -s first -n vite,electron -c \"cyan,magenta\" \"pnpm dev\" \"wait-on tcp:5280 && electron .\"",
    "shell:build": "pnpm build && electron ."
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.0.1",
    "electron": "^33.0.0",
    "typescript": "^5.6.3",
    "vite": "^6.0.7",
    "wait-on": "^8.0.1"
  }
}
